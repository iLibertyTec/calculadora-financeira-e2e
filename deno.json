{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check main.ts routes/**/*.ts routes/**/*.tsx components/**/*.ts components/**/*.tsx islands/**/*.ts islands/**/*.tsx src/**/*.ts vite.config.ts",
    "dev": "deno run -A --watch main.ts",
    "test": "deno test -A",
    "start": "deno run -A main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "$fresh": "jsr:@fresh/core@2.0.0-alpha.29",
    "$fresh/": "jsr:@fresh/core@2.0.0-alpha.29/",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@0.0.2-alpha.29",
    "@preact/signals": "npm:@preact/signals@2.0.1",
    "@preact/signals-core": "npm:@preact/signals-core@1.8.0",
    "preact": "npm:preact@10.26.4",
    "preact/": "npm:preact@10.26.4/",
    "preact/jsx-runtime": "npm:preact@10.26.4/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@10.26.4/jsx-dev-runtime",
    "preact-render-to-string": "npm:preact-render-to-string@6.5.13",
    "vite": "npm:vite@6.3.5"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.unstable"]
  },
  "deploy": {
    "install": "deno install",
    "build": "echo 'no build step'",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "main.ts"
    }
  }
}
